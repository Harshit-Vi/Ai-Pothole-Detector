# ===============================
# Backend Environment Variables
# ===============================

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/pothole_detector
DB_USER=pothole_user
DB_PASSWORD=secure_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pothole_detector

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS Configuration (for S3 image storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=pothole-detector-images

# Twilio Configuration (SMS Notifications)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid Configuration (Email Notifications)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=notifications@potholedetector.com

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_BASE_URL=http://localhost:5000

# Model Configuration
MODEL_PATH=./models/trained_model.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.4

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===============================
# Frontend Environment Variables
# ===============================

# React Configuration
REACT_APP_API_BASE_URL=http://localhost:5000/api
REACT_APP_MAP_API_KEY=your-map-api-key
REACT_APP_ENV=development

# ===============================
# Mobile App Environment Variables
# ===============================

# React Native Configuration
REACT_NATIVE_API_BASE_URL=http://localhost:5000/api
REACT_NATIVE_ENV=development

# ===============================
# Training Pipeline Variables
# ===============================

# Model Training
TRAINING_EPOCHS=100
BATCH_SIZE=32
LEARNING_RATE=0.001
DEVICE=cuda

# Dataset Configuration
DATASET_PATH=./training/datasets
TRAIN_DATA_PATH=./training/datasets/train
VAL_DATA_PATH=./training/datasets/val
TEST_DATA_PATH=./training/datasets/test

# ===============================
# Deployment Configuration
# ===============================

# Docker Configuration
DOCKER_REGISTRY=your-registry
DOCKER_IMAGE_NAME=ai-pothole-detector
DOCKER_IMAGE_TAG=latest

# Kubernetes Configuration (if using K8s)
K8S_NAMESPACE=default
K8S_REPLICAS=3

# ===============================
# Monitoring & Analytics
# ===============================

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# ===============================
# Municipality Configuration
# ===============================

# Default Municipality Contact
MUNICIPALITY_NAME=Test Municipality
MUNICIPALITY_EMAIL=admin@municipality.com
MUNICIPALITY_PHONE=+91234567890

# Report Configuration
AUTO_REPORT_ENABLED=true
REPORT_THRESHOLD_SEVERITY=medium

# ===============================
# Feature Flags
# ===============================

ENABLE_GPS_TAGGING=true
ENABLE_AUTO_REPORTING=true
ENABLE_SEVERITY_CLASSIFICATION=true
ENABLE_REAL_TIME_PROCESSING=true
